# Debug mode: when 'true', the Results view shows a player + download for the
# demucs-separated vocal stem, so you can hear whether vocal separation failed
# on a given sample. Internal/debugging only — leave unset or 'false' for users.
# Requires a Vite restart to take effect (build-time env var).
VITE_DEBUG_VOCALS=false

# Feature flag: when 'true', shows an "import from YouTube" panel under the
# dropzone — fetch a video's audio, slice it on a waveform, then analyze the
# chosen segment. Requires a Vite restart to take effect.
VITE_ENABLE_YT_IMPORT=false
